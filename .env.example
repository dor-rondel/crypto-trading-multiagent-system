# Groq API Key
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.1-8b-instant

# News API Key
NEWS_API_KEY=your_newsapi_key_here

# LangSmith for Observability
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=crypto-trading-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Wallet Management ---

# Solana Devnet
# Provide a base58 encoded private key or leave blank for programmatic creation
SOLANA_PRIVATE_KEY=

# Coinbase CDP (EVM - Sepolia & Fuji)
# These are required for AgentKit/CDP operations
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# EVM Wallet Persistence
# The system will store/load the CDP wallet data from these files if provided
SEPOLIA_WALLET_DATA_FILE=sepolia_wallet.json
FUJI_WALLET_DATA_FILE=fuji_wallet.json

# --- Chain RPCs (Optional, SDKs often have defaults) ---
SOLANA_RPC_URL=
ETH_SEPOLIA_RPC_URL=
AVAX_FUJI_RPC_URL=

# --- Market Data ---
COINGECKO_API_KEY=
