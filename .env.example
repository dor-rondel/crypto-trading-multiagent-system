# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# LangSmith Observability
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT="crypto-trading-agent"

# Coinbase AgentKit Credentials
CDP_API_KEY_NAME=your_cdp_api_key_name
CDP_API_KEY_PRIVATE_KEY=your_cdp_private_key

# Testnet Wallet Private Keys (DO NOT USE MAINNET KEYS)
SOLANA_PRIVATE_KEY=your_solana_devnet_private_key
ETH_SEPOLIA_PRIVATE_KEY=your_eth_sepolia_private_key
AVALANCHE_FUJI_PRIVATE_KEY=your_avalanche_fuji_private_key

# RPC URLs (Optional)
SOLANA_RPC_URL=https://api.devnet.solana.com
ETH_SEPOLIA_RPC_URL=
AVALANCHE_FUJI_RPC_URL=
